---
type SectionTag = "section" | "div" | "article" | "aside" | "header" | "footer";

interface Props {
  id?: string;
  variant?: "default" | "alt" | "tech";
  width?: "default" | "narrow";
  paddingY?: "default" | "lg" | "sm";
  as?: SectionTag;
  class?: string;
}

const {
  id,
  variant = "default",
  width = "default",
  paddingY = "default",
  as: Tag = "section",
  class: className = "",
} = Astro.props;
---

<Tag
  id={id}
  data-theme={variant === "tech" ? "tech" : undefined}
  class:list={["section", `section--${variant}`, `section--py-${paddingY}`, className]}
>
  <div class:list={["section__inner", width === "narrow" && "section__inner--narrow"]}>
    <slot />
  </div>
</Tag>

<style>
  .section {
    width: 100%;
    background: var(--color-bg);
    color: var(--color-fg);
  }
  .section--alt {
    background: var(--color-surface);
    border-block: 1px solid var(--color-border);
  }
  .section--tech {
    background: var(--color-bg);
    color: var(--color-fg);
  }
  .section--py-default {
    padding-block: var(--space-8);
  }
  .section--py-lg {
    padding-block: var(--space-9);
  }
  .section--py-sm {
    padding-block: var(--space-7);
  }

  .section__inner {
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-5);
  }
  .section__inner--narrow {
    max-width: var(--container-prose);
  }
</style>
